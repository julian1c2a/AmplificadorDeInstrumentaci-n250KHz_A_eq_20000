R6          12 11 500 
R5          6 11 49.5K 
R4          5 12 49.5K 
XOP4         4 11 cc dd 6 6 cc ADA4817
XOP3         3 12 cc dd 5 5 cc ADA4817
R3          14 13 500 
R2          4 13 49.5K 
R1          3 14 49.5K 
XOP2         in 13 cc dd 4 4 cc ADA4817
XOP1         0 14 cc dd 3 3 cc ADA4817

* Simulation Control block
.control
  * 1. DC Linearity Sweep
  dc Vin -35u 35u 0.1u
  wrdata superopamp_dc.txt v(out)
  
  * 2. AC Frequency Response Sweep (Bode)
  ac dec 100 1 100meg
  let gain_db = vdb(out)
  let phase_rad = ph(v(out))
  let phase_deg = phase_rad * 180 / 3.141592653589793
  wrdata superopamp_ac.txt gain_db phase_deg
  
  * 3. Transient Response Analysis
  * 10Hz frequency, 3 cycles = 300ms. Step size 100us.
  tran 100u 300m
  wrdata superopamp_tran.txt v(in) v(out)
  
  echo "=== SIMULATION COMPLETED SUCCESSFULLY ==="
.endc

.END
